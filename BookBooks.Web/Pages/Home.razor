@page "/"
@inject AuthSession AuthSession

<PageTitle>Home</PageTitle>

<h1>BookBooks</h1>

<p>Fluxo inicial disponível: cadastro/login, busca/criação de livros, detalhe do livro e publicação de review.</p>

@if (AuthSession.IsAuthenticated)
{
    <p><strong>Conectado como:</strong> @AuthSession.CurrentUser!.Username (@AuthSession.CurrentUser.Email)</p>
}
else
{
    <p>Você não está autenticado. Acesse a página de login para publicar reviews.</p>
}

<p>Acesse <a href="/books">/books</a> para buscar, criar e abrir livros.</p>
