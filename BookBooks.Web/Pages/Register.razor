@page "/register"
@using System.ComponentModel.DataAnnotations
@inject AuthApiClient AuthApiClient
@inject AuthSession AuthSession
@inject NavigationManager NavigationManager

<PageTitle>Criar Conta</PageTitle>

<h1>Criar Conta</h1>

<EditForm Model="_model" OnValidSubmit="HandleRegisterAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="username">Usuário</label>
        <InputText id="username" class="form-control" @bind-Value="_model.Username" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="email">Email</label>
        <InputText id="email" class="form-control" @bind-Value="_model.Email" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="password">Senha</label>
        <InputText id="password" class="form-control" type="password" @bind-Value="_model.Password" />
    </div>

    <button class="btn btn-primary" disabled="@_isSubmitting" type="submit">
        @_buttonLabel
    </button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@code {
    private readonly RegisterFormModel _model = new();
    private bool _isSubmitting;
    private string? _error;

    private string _buttonLabel => _isSubmitting ? "Criando conta..." : "Criar conta";

    protected override void OnInitialized()
    {
        if (AuthSession.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/");
        }
    }

    private async Task HandleRegisterAsync()
    {
        _error = null;
        _isSubmitting = true;

        try
        {
            var response = await AuthApiClient.RegisterAsync(new RegisterRequest(
                _model.Username,
                _model.Email,
                _model.Password));

            await AuthSession.SignInAsync(response);
            NavigationManager.NavigateTo("/");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (HttpRequestException)
        {
            _error = "Nao foi possivel conectar com a API. Verifique se o BookBooks.API esta em execucao.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private sealed class RegisterFormModel
    {
        [Required]
        [MinLength(3)]
        [MaxLength(50)]
        public string Username { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        [MinLength(6)]
        public string Password { get; set; } = string.Empty;
    }
}
