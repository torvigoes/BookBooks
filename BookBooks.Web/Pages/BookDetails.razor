@page "/books/{BookId}"
@using System.ComponentModel.DataAnnotations
@inject BooksApiClient BooksApiClient
@inject ReviewsApiClient ReviewsApiClient
@inject ReadingStatusApiClient ReadingStatusApiClient
@inject AuthSession AuthSession
@inject NavigationManager NavigationManager

<PageTitle>Livro</PageTitle>

@if (_isLoading)
{
    <p>Carregando...</p>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <p class="text-danger">@_loadError</p>
}
else if (_book is not null)
{
    <h1>@_book.Title</h1>
    <p><strong>Autor:</strong> @_book.Author</p>
    <p><strong>Ano:</strong> @_book.Year</p>
    <p><strong>ISBN:</strong> @_book.Isbn</p>
    <p><strong>Nota media:</strong> @_book.AverageRating.ToString("0.00") (@_book.ReviewCount avaliacoes)</p>

    @if (AuthSession.IsAuthenticated)
    {
        <section class="mt-4 mb-4">
            <h2>Status de leitura</h2>

            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label" for="reading-status">Selecione o status</label>
                    <InputSelect id="reading-status" class="form-select" @bind-Value="_selectedReadingStatus">
                        <option value="@ReadingStatusType.WantToRead">Quero ler</option>
                        <option value="@ReadingStatusType.CurrentlyReading">Lendo</option>
                        <option value="@ReadingStatusType.Read">Lido</option>
                        <option value="@ReadingStatusType.Abandoned">Abandonado</option>
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-outline-primary" disabled="@_isSavingReadingStatus" @onclick="SaveReadingStatusAsync">
                        @(_isSavingReadingStatus ? "Salvando..." : "Salvar status")
                    </button>
                </div>
            </div>

            @if (_currentReadingStatus is not null)
            {
                <p class="mt-2 mb-0">
                    Status atual: <strong>@FormatReadingStatus(_currentReadingStatus.Status)</strong>
                    (atualizado em @_currentReadingStatus.UpdatedAt.ToLocalTime().ToString("g"))
                </p>
            }

            @if (!string.IsNullOrWhiteSpace(_readingStatusError))
            {
                <p class="text-danger mt-2">@_readingStatusError</p>
            }
        </section>
    }

    <h2 class="mt-4">Reviews</h2>
    @if (_reviews.Count == 0)
    {
        <p>Nenhuma review ainda.</p>
    }
    else
    {
        @foreach (var review in _reviews)
        {
            <article class="mb-3 p-3 border rounded">
                <p><strong>@review.UserDisplayName</strong> - Nota @review.Rating/5</p>
                <p>@review.Content</p>
                @if (review.ContainsSpoiler)
                {
                    <p><em>Contem spoiler.</em></p>
                }
            </article>
        }
    }

    @if (AuthSession.IsAuthenticated)
    {
        <h3 class="mt-4">Adicionar review</h3>
        <EditForm Model="_createReviewModel" OnValidSubmit="CreateReviewAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label" for="rating">Nota (1 a 5)</label>
                <InputNumber id="rating" class="form-control" @bind-Value="_createReviewModel.Rating" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="content">Conteudo</label>
                <InputTextArea id="content" class="form-control" @bind-Value="_createReviewModel.Content" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox id="spoiler" class="form-check-input" @bind-Value="_createReviewModel.ContainsSpoiler" />
                <label class="form-check-label" for="spoiler">Contem spoiler</label>
            </div>

            <button class="btn btn-primary" disabled="@_isSubmittingReview" type="submit">
                @(_isSubmittingReview ? "Enviando..." : "Publicar review")
            </button>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(_reviewError))
        {
            <p class="text-danger mt-3">@_reviewError</p>
        }
    }
    else
    {
        <p class="mt-3">Entre com sua conta para publicar review. <a href="/login">Ir para login</a>.</p>
    }
}

@code {
    [Parameter]
    public string BookId { get; set; } = string.Empty;

    private BookDto? _book;
    private List<ReviewDto> _reviews = [];
    private bool _isLoading = true;
    private bool _isSubmittingReview;
    private bool _isSavingReadingStatus;
    private string? _loadError;
    private string? _reviewError;
    private string? _readingStatusError;
    private ReadingStatusDto? _currentReadingStatus;
    private ReadingStatusType _selectedReadingStatus = ReadingStatusType.WantToRead;
    private readonly CreateReviewFormModel _createReviewModel = new();

    protected override async Task OnParametersSetAsync()
    {
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            _book = await BooksApiClient.GetByIdAsync(BookId);
            var reviews = await ReviewsApiClient.GetByBookAsync(BookId);
            _reviews = [.. reviews];

            if (AuthSession.IsAuthenticated)
            {
                await LoadReadingStatusAsync();
            }
        }
        catch (ApiException ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadReadingStatusAsync()
    {
        _readingStatusError = null;

        try
        {
            _currentReadingStatus = await ReadingStatusApiClient.GetByBookAsync(BookId);
            _selectedReadingStatus = _currentReadingStatus.Status;
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            _currentReadingStatus = null;
        }
        catch (ApiException ex)
        {
            _readingStatusError = ex.Message;
        }
    }

    private async Task SaveReadingStatusAsync()
    {
        _readingStatusError = null;
        _isSavingReadingStatus = true;

        try
        {
            _currentReadingStatus = await ReadingStatusApiClient.UpsertAsync(
                BookId,
                new UpdateReadingStatusRequest(_selectedReadingStatus));
        }
        catch (ApiException ex)
        {
            if (ex.StatusCode == 401)
            {
                await AuthSession.SignOutAsync();
                _readingStatusError = "Sua sessao expirou. Faca login novamente.";
                NavigationManager.NavigateTo("/login");
                return;
            }

            _readingStatusError = ex.Message;
        }
        finally
        {
            _isSavingReadingStatus = false;
        }
    }

    private async Task CreateReviewAsync()
    {
        _reviewError = null;
        _isSubmittingReview = true;

        try
        {
            var request = new CreateReviewRequest(
                _createReviewModel.Rating,
                _createReviewModel.Content,
                _createReviewModel.ContainsSpoiler);

            await ReviewsApiClient.CreateAsync(BookId, request);
            _createReviewModel.Content = string.Empty;
            _createReviewModel.ContainsSpoiler = false;
            _createReviewModel.Rating = 5;

            await LoadPageAsync();
        }
        catch (ApiException ex)
        {
            if (ex.StatusCode == 401)
            {
                await AuthSession.SignOutAsync();
                _reviewError = "Sua sessao expirou. Faca login novamente.";
                NavigationManager.NavigateTo("/login");
                return;
            }

            _reviewError = ex.Message;
        }
        finally
        {
            _isSubmittingReview = false;
        }
    }

    private sealed class CreateReviewFormModel
    {
        [Range(1, 5)]
        public int Rating { get; set; } = 5;

        [Required]
        [MinLength(10)]
        [MaxLength(5000)]
        public string Content { get; set; } = string.Empty;

        public bool ContainsSpoiler { get; set; }
    }

    private static string FormatReadingStatus(ReadingStatusType status)
    {
        return status switch
        {
            ReadingStatusType.WantToRead => "Quero ler",
            ReadingStatusType.CurrentlyReading => "Lendo",
            ReadingStatusType.Read => "Lido",
            ReadingStatusType.Abandoned => "Abandonado",
            _ => status.ToString()
        };
    }
}
