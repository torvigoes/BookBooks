@page "/login"
@using System.ComponentModel.DataAnnotations
@inject AuthApiClient AuthApiClient
@inject AuthSession AuthSession
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<h1>Entrar</h1>
<p>Ainda não tem conta? <a href="/register">Criar conta</a>.</p>

<EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="email">Email</label>
        <InputText id="email" class="form-control" @bind-Value="_model.Email" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="password">Senha</label>
        <InputText id="password" class="form-control" type="password" @bind-Value="_model.Password" />
    </div>

    <button class="btn btn-primary" disabled="@_isSubmitting" type="submit">
        @_buttonLabel
    </button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@code {
    private readonly LoginFormModel _model = new();
    private bool _isSubmitting;
    private string? _error;

    private string _buttonLabel => _isSubmitting ? "Entrando..." : "Entrar";

    protected override void OnInitialized()
    {
        if (AuthSession.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/");
        }
    }

    private async Task HandleLoginAsync()
    {
        _error = null;
        _isSubmitting = true;

        try
        {
            var response = await AuthApiClient.LoginAsync(new LoginRequest(_model.Email, _model.Password));
            await AuthSession.SignInAsync(response);
            NavigationManager.NavigateTo("/");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (HttpRequestException)
        {
            _error = "Nao foi possivel conectar com a API. Verifique se o BookBooks.API esta em execucao.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private sealed class LoginFormModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }
}
